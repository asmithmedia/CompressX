{
  "name": "compressx",
  "version": "0.5.0",
  "description": "Compress LLM models for Ollama in one command. Keeps your originals, adds a -cx variant. Hardware-aware, fully local, no account required.",
  "type": "module",
  "bin": {
    "compressx": "./dist/compressx.js"
  },
  "main": "./dist/compressx.js",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx bin/compressx.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "llm",
    "compression",
    "gguf",
    "ollama",
    "quantization",
    "llama-cpp",
    "ai",
    "model",
    "cli",
    "quantize",
    "local-llm"
  ],
  "author": "A. Smith Media",
  "license": "UNLICENSED",
  "homepage": "https://compressx.asmith.media",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "inquirer": "^9.0.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
